{
  "manifest_version": 3,
  "name": "Bruno Web Recorder",
  "description": "Record browser actions, screenshots, console errors, and network traffic into Bruno.",
  "version": "0.1.0",
  "minimum_chrome_version": "118",
  "permissions": ["debugger", "scripting", "tabs", "storage"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1/*", "http://localhost/*"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Bruno Web Recorder",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
